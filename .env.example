# =============================================================
# DataPulse — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER put real credentials in this file.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# ── Service DB connection URLs (used inside Docker network) ──
DATABASE_URL=postgresql://your_db_user:your_db_password@db:5432/your_db_name
SOURCE_DB_URL=postgresql://your_db_user:your_db_password@db:5432/your_db_name
TARGET_DB_URL=postgresql://your_db_user:your_db_password@db:5432/your_db_name
AIRFLOW_DB_URL=postgresql+psycopg2://your_db_user:your_db_password@db:5432/your_db_name

# ── PgAdmin ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_ADMIN_PASSWORD=your_airflow_password

# ── Alerting (optional) ───────────────────────────────────────
DE_ALERT_EMAILS=
SLACK_WEBHOOK_URL=
